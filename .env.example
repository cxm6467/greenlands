# Anthropic Claude API
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Multi-Chat MCP Server
MCP_SERVER_URL=http://localhost:3000
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages
DISCORD_BOT_TOKEN=your-discord-bot-token
SLACK_APP_TOKEN=xoxb-your-slack-token

# Feature Flags
ENABLE_QUEST_GENERATION=true
ENABLE_CHAT_BOTS=false
ENABLE_NOTIFICATIONS=true
ENABLE_RECURRING_EVENTS=true

# Game Config
MAX_FELLOWSHIP_SIZE=8
XP_MULTIPLIER=1.0
DAILY_QUEST_RESET_HOUR=0
DEBUG_MODE=true
