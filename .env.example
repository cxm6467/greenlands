# AI Provider Configuration
# Options: 'claude' or 'bedrock'
AI_PROVIDER=claude

# Anthropic Claude API Configuration (if using claude provider)
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# AWS Bedrock Configuration (if using bedrock provider)
# Note: AWS credentials are configured in proxy only, not in app
BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# AI Proxy URL for web builds (supports both Claude and Bedrock)
# Local development: http://localhost:3001 (standalone proxy)
# Production: https://your-project.web.app/api/claude (Firebase Cloud Function)
# See proxy/README.md or PRODUCTION_PROXY_SETUP.md for details
AI_PROXY_URL=http://localhost:3001

# Multi-Chat MCP Server
MCP_SERVER_URL=http://localhost:3000
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages
DISCORD_BOT_TOKEN=your-discord-bot-token
SLACK_APP_TOKEN=xoxb-your-slack-token

# Feature Flags
ENABLE_QUEST_GENERATION=true
ENABLE_CHAT_BOTS=false
ENABLE_NOTIFICATIONS=true
ENABLE_RECURRING_EVENTS=true

# Game Config
MAX_FELLOWSHIP_SIZE=8
XP_MULTIPLIER=1.0
DAILY_QUEST_RESET_HOUR=0
DEBUG_MODE=true
