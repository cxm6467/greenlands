# AI Provider Configuration
# Options: 'claude' or 'bedrock'
AI_PROVIDER=claude

# Claude API Configuration (if using AI_PROVIDER=claude)
CLAUDE_API_KEY=sk-ant-your-key-here

# AWS Bedrock Configuration (if using AI_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Server configuration
PORT=3001
HOST=0.0.0.0

# CORS origins allowed to call this proxy (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost
